# 应用基础配置
APP_ENV=dev
APP_PORT=8000
APP_NAME=PV QA Assistant
MODEL_API_TIMEOUT_SECONDS=180

# PostgreSQL 本地数据库配置
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=operation_pv
DB_USER=postgres
DB_PASSWORD=your_password

# Redis 预留配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# SiliconFlow Chat 模型配置
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_API_KEY=your_api_key
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash

# SiliconFlow Embedding 模型配置
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=your_api_key
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# SiliconFlow Rerank 模型配置
RERANK_BASE_URL=https://api.siliconflow.cn/v1
RERANK_API_KEY=your_api_key
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_ENABLED=true
RERANK_TOP_N=5

# 检索参数
RETRIEVAL_VECTOR_TOP_K=20
RETRIEVAL_KEYWORD_TOP_K=20
RETRIEVAL_RRF_TOP_K=20
RETRIEVAL_FINAL_TOP_K=5
RETRIEVAL_RRF_K=60

# QA 路由和阈值配置
QA_RERANK_MIN_SCORE=0.2
QA_RERANK_STRONG_SCORE=0.6
QA_MAX_QUESTION_CHARS=500
QA_REFERENCE_TOP_K=5
QA_INTENT_MODEL=deepseek-ai/DeepSeek-V4-Flash
QA_CHAT_MODEL=deepseek-ai/DeepSeek-V4-Flash

# 进入最终 chat 生成的证据最低 rerank 分数
QA_EVIDENCE_MIN_SCORE=0.3
# 返回给前端作为引用展示的最低 rerank 分数
QA_REFERENCE_MIN_SCORE=0.3
# 前端默认展开显示的引用数量
QA_REFERENCE_VISIBLE_TOP_K=3
# 后端最多返回给前端折叠展示的引用数量
QA_REFERENCE_MAX_TOP_K=5

# QA 调试日志开关：前端联调时可设为 true，控制台会输出 qa_debug JSON 单行日志
QA_DEBUG_LOG_ENABLED=false
# 问题、改写问题、检索词在日志中的最大预览长度，避免控制台输出完整长文本
QA_DEBUG_QUESTION_PREVIEW_CHARS=80
# 是否在日志中输出证据/引用对象预览；默认 false，只输出数量
QA_DEBUG_EVIDENCE_PREVIEW_ENABLED=false

# 多轮会话配置
CONVERSATION_HISTORY_TURNS=10
CONVERSATION_SUMMARY_AFTER_TURNS=10
CONVERSATION_SUMMARY_REFRESH_TURNS=5
CONVERSATION_CONTEXT_MAX_CHARS=8000
CONVERSATION_ANSWER_EXCERPT_CHARS=500
